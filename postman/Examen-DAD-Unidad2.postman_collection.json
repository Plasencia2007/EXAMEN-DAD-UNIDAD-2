          },
          "response": []
        },
        {
          "name": "Eliminar inscripcion",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{gateway}}/api/inscripciones/1",
              "host": ["{{gateway}}"],
              "path": ["api", "inscripciones", "1"]
            },
            "description": "Elimina una inscripcion por su id. Responde 204."
          },
          "response": []
        }
      ]
    },
