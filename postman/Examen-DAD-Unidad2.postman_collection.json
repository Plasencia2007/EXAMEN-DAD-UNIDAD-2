            "header": [],
            "url": {
              "raw": "{{gateway}}/api/permisos",
              "host": ["{{gateway}}"],
              "path": ["api", "permisos"]
            },
            "description": "Lista todos los permisos. Requiere rol ADMIN."
          },
          "response": []
        }
      ]
    },
