    {
      "name": "3. Talleres (compuesto)",
      "description": "Microservicio **ms-gestion-taller** (tabla `taller`). Servicio COMPUESTO: consume a instructores y alumnos via OpenFeign. Base: `/api/talleres`.",
      "item": [
        {
          "name": "Listar talleres",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway}}/api/talleres",
              "host": ["{{gateway}}"],
              "path": ["api", "talleres"]
            },
            "description": "Devuelve la lista de todos los talleres."
          },
          "response": []
        },
        {
          "name": "Buscar taller por id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway}}/api/talleres/1",
              "host": ["{{gateway}}"],
              "path": ["api", "talleres", "1"]
            },
            "description": "Devuelve un taller por su id (datos propios, sin instructor ni alumnos)."
          },
          "response": []
        },
        {
          "name": "Detalle del taller (vista compuesta)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway}}/api/talleres/1/detalle",
              "host": ["{{gateway}}"],
              "path": ["api", "talleres", "1", "detalle"]
            },
            "description": "**Vista COMPUESTA**: devuelve el taller + el instructor completo (microservicio de instructores) + la lista de alumnos inscritos (microservicio de alumnos) + cupos disponibles. Todo reunido mediante OpenFeign."
          },
          "response": []
        },
        {
          "name": "Crear taller",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Acuarela basica\",\n  \"descripcion\": \"Taller introductorio de acuarela\",\n  \"fechaInicio\": \"2026-07-01\",\n  \"cupoMaximo\": 20,\n  \"idInstructor\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway}}/api/talleres",
              "host": ["{{gateway}}"],
              "path": ["api", "talleres"]
            },
            "description": "Crea un taller. Valida via OpenFeign que el instructor (idInstructor) exista. Campos obligatorios: nombre, cupoMaximo (>0), idInstructor. Responde 201."
          },
          "response": []
        },
        {
          "name": "Actualizar taller",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Acuarela intermedia\",\n  \"descripcion\": \"Nivel intermedio\",\n  \"fechaInicio\": \"2026-08-01\",\n  \"cupoMaximo\": 15,\n  \"idInstructor\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway}}/api/talleres/1",
              "host": ["{{gateway}}"],
              "path": ["api", "talleres", "1"]
            },
            "description": "Actualiza un taller existente (revalida el instructor)."
          },
          "response": []
        },
        {
          "name": "Eliminar taller",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{gateway}}/api/talleres/1",
              "host": ["{{gateway}}"],
              "path": ["api", "talleres", "1"]
            },
            "description": "Elimina un taller y sus inscripciones asociadas. Responde 204."
          },
          "response": []
        },
        {
          "name": "Inscribir alumno (proceso de negocio)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{gateway}}/api/talleres/1/inscribir/1",
              "host": ["{{gateway}}"],
              "path": ["api", "talleres", "1", "inscribir", "1"]
            },
            "description": "Inscribe al alumno {idAlumno} en el taller {idTaller}. Valida que el alumno exista (Feign), que haya cupo disponible y que no este ya inscrito. Responde 201."
          },
          "response": []
        },
        {
          "name": "Cancelar inscripcion (proceso de negocio)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{gateway}}/api/talleres/1/inscribir/1",
              "host": ["{{gateway}}"],
              "path": ["api", "talleres", "1", "inscribir", "1"]
            },
            "description": "Cancela la inscripcion del alumno {idAlumno} en el taller {idTaller}. Responde 204."
          },
          "response": []
        }
      ]
    },
    {
